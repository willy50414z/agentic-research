VOLUME_BASE_DIR=E:/docker_data/agentic-research/
COMPOSE_FILE=deploy/docker-compose.local.yml

# ---------------------------------------------------------------------------
# PostgreSQL (shared by Planka + LangGraph)
# ---------------------------------------------------------------------------
POSTGRES_USER=agentic-postgres-user
POSTGRES_PASSWORD=agentic-postgres-pwd
POSTGRES_DB=agentic-research
POSTGRES_HOST_AUTH_METHOD=trust

# Inside container: use hostname "postgres"
# Local (host machine): use "localhost"
DATABASE_URL=postgresql://agentic-postgres-user:agentic-postgres-pwd@postgres:5432/agentic-research

# ---------------------------------------------------------------------------
# LangGraph app
# ---------------------------------------------------------------------------
ARTIFACTS_DIR=/app/artifacts

# ---------------------------------------------------------------------------
# MLflow (optional experiment tracking)
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---------------------------------------------------------------------------
# Planka
# ---------------------------------------------------------------------------
BASE_URL=http://localhost:7002
SECRET_KEY=replace_this_with_a_long_random_secret_key
DEFAULT_ADMIN_EMAIL=agentic@local.dev
DEFAULT_ADMIN_PASSWORD=agentic-planka-pwd
DEFAULT_ADMIN_NAME=Agentic Admin
DEFAULT_ADMIN_USERNAME=agentic-admin
PLANKA_API_URL=http://agentic-planka:1337
PLANKA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjNmMGU5YzA2LTIyZWQtNGQzOS04OGUwLWUxZWIyNjc4ZGQxMyJ9.eyJpYXQiOjE3NzM5ODUyNDAsImV4cCI6MTgwNTUyMTI0MCwic3ViIjoiMTczNDAyODgxNjQ3ODYzNTAwOSJ9.eTFYz4khorwYv3nQKqldjGzgIji4F5ImjSfi77o4J1c
PLANKA_BOARD_ID=1734711349730083850

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=agentic-minio-user
MINIO_ROOT_PASSWORD=agentic-minio-pwd

# ---------------------------------------------------------------------------
# LLM 整合
# LLM_CHAIN 可用值：claude-cli, claude-api, gemini-cli, gemini-api, openai-api, local
# ---------------------------------------------------------------------------
LLM_CHAIN=claude-cli
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2
