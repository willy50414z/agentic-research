VOLUME_BASE_DIR=E:/docker_data/agentic-research/
COMPOSE_FILE=docker/docker-compose.yml

# ---------------------------------------------------------------------------
# PostgreSQL (shared by Planka + LangGraph)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic-research
POSTGRES_HOST_AUTH_METHOD=trust

# Used by LangGraph checkpointer and business schema queries
# Inside container: use hostname "postgres"
# Local (host machine): use "localhost" after exposing port 5432 in docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic-research

# ---------------------------------------------------------------------------
# LangGraph app
# ---------------------------------------------------------------------------
ARTIFACTS_DIR=/app/artifacts

# ---------------------------------------------------------------------------
# MLflow (optional experiment tracking)
# ---------------------------------------------------------------------------
# Inside container the MLflow service hostname is "mlflow"
# From host machine use http://localhost:5000 for the UI
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---------------------------------------------------------------------------
# Planka (optional HITL visual layer)
# ---------------------------------------------------------------------------
BASE_URL=http://localhost:7002
SECRET_KEY=replace_this_with_a_long_random_secret_key
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=adminpassword
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_USERNAME=admin
PLANKA_API_URL=http://localhost:7002
